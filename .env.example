# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://oxycure:oxycure_secret_2026@localhost:5432/oxycure_erp?schema=public"

# ============================================
# REDIS
# ============================================
REDIS_URL="redis://:oxycure_redis_2026@localhost:6379"

# ============================================
# API (NestJS) — apps/api/.env
# ============================================
NODE_ENV=development
PORT=3001

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production_min_32_chars
JWT_REFRESH_EXPIRY=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ============================================
# WEB (Next.js) — apps/web/.env.local
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXTAUTH_SECRET=your_nextauth_secret_change_in_production
NEXTAUTH_URL=http://localhost:3000
