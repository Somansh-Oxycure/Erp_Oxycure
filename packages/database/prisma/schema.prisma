// ============================================
// PRISMA SCHEMA — Oxycure ERP Phase 1
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  admin
  manager
  salesperson
  installer
  service_engineer
  design_engineer
  finance
}

enum Department {
  sales
  operations
  service
  admin
  finance
  design
}

enum TicketStatus {
  new
  contacted
  site_inspection
  design_review
  quoted
  won
  lost
}

enum TicketSource {
  direct_enquiry
  website
  referral
  walk_in
  cold_call
  social_media
  exhibition
  partner
  other
}

enum Priority {
  low
  medium
  high
  urgent
}

enum ProductType {
  air_purifier
  moscure
  industrial_solution
  hvac
  other
}

enum NoteType {
  general
  follow_up
  meeting
  call
  status_change
  site_inspection
  design_review
}

enum FollowUpStatus {
  pending
  completed
  missed
  rescheduled
}

enum CustomerType {
  individual
  business
  hospital
  clinic
  government
  other
}

enum DesignSpecStatus {
  requested
  in_progress
  completed
  approved
  revision_needed
}

enum QuotationStatus {
  draft
  sent
  accepted
  rejected
  expired
}

enum ProposalStatus {
  draft
  sent
  accepted
  rejected
  expired
}

enum OrderStatus {
  created
  confirmed
  in_progress
  completed
  cancelled
  on_hold
}

// ============================================
// MODELS
// ============================================

model User {
  id                    String    @id @default(uuid())
  employeeId            String    @unique @map("employee_id")
  firstName             String    @map("first_name")
  lastName              String    @map("last_name")
  email                 String    @unique
  phone                 String
  passwordHash          String    @map("password_hash")
  role                  UserRole
  department            Department
  isActive              Boolean   @default(true) @map("is_active")
  lastLoginAt           DateTime? @map("last_login_at")
  failedLoginAttempts   Int       @default(0) @map("failed_login_attempts")
  lockedUntil           DateTime? @map("locked_until")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  // Ticket relations
  assignedTickets         Ticket[]              @relation("TicketAssignedTo")
  createdTickets          Ticket[]              @relation("TicketCreatedBy")
  convertedTickets        Ticket[]              @relation("TicketConvertedBy")
  ticketNotes             TicketNote[]
  ticketFollowUps         TicketFollowUp[]      @relation("TicketFollowUpCreatedBy")
  ticketStatusHistories   TicketStatusHistory[] @relation("StatusHistoryChangedBy")
  proposalFollowUps       ProposalFollowUp[]    @relation("ProposalFollowUpCreatedBy")
  proposalNotes           ProposalNote[]

  // Other relations
  designedSpecs         DesignSpecification[] @relation("DesignedSpecs")
  reviewedSpecs         DesignSpecification[] @relation("ReviewedSpecs")
  siteInspections       DesignSpecification[] @relation("SiteInspections")
  createdSpecs          DesignSpecification[] @relation("CreatedSpecs")
  createdQuotations     Quotation[]
  createdOrders         Order[]
  createdCustomers      Customer[]
  createdProposals      Proposal[]            @relation("CreatedProposals")
  refreshTokens         RefreshToken[]
  auditLogs             AuditLog[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Customer {
  id             String       @id @default(uuid())
  customerNumber String       @unique @map("customer_number")
  firstName      String       @map("first_name")
  lastName       String?      @map("last_name")
  email          String?
  phone          String       @unique
  alternatePhone String?      @map("alternate_phone")
  companyName    String?      @map("company_name")
  designation    String?
  gstNumber      String?      @map("gst_number")
  addressLine1   String?      @map("address_line1")
  addressLine2   String?      @map("address_line2")
  city           String
  state          String
  pincode        String?
  customerType   CustomerType @default(individual) @map("customer_type")
  ticketId       String?      @unique @map("ticket_id")
  createdById    String       @map("created_by")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Relations
  ticket         Ticket?               @relation(fields: [ticketId], references: [id])
  createdBy      User                  @relation(fields: [createdById], references: [id])
  orders         Order[]
  quotations     Quotation[]
  designSpecs    DesignSpecification[]

  @@index([phone])
  @@map("customers")
}

model ReferenceCounter {
  id      String @id          // financial-year label, e.g. "26/27"
  lastSeq Int    @default(0)

  @@map("reference_counters")
}

model Ticket {
  id             String        @id @default(uuid())
  referenceId    String        @unique @map("reference_id")

  // ── Contact / Client ──────────────────────────────
  clientName     String        @map("client_name")
  name           String        // contact person at client side
  clientLocation String?       @map("client_location")
  region         String?
  phone          String
  alternatePhone String?       @map("alternate_phone")
  email          String?

  // ── Project ───────────────────────────────────────
  projectName     String?      @map("project_name")
  projectLocation String?      @map("project_location")

  // ── Consultant ────────────────────────────────────
  consultantName     String?   @map("consultant_name")
  consultantLocation String?   @map("consultant_location")

  // ── Architect ─────────────────────────────────────
  architectName     String?    @map("architect_name")
  architectLocation String?    @map("architect_location")

  // ── Deal Info ─────────────────────────────────────
  approveMake      String?     @map("approve_make")
  productType      ProductType? @map("product_type")
  estimatedValue   Decimal?    @map("estimated_value") @db.Decimal(12, 2)
  requirementNotes String?     @map("requirement_notes") @db.Text

  // ── Pipeline ──────────────────────────────────────
  status           TicketStatus @default(new)
  priority         Priority     @default(medium)
  source           TicketSource @default(other)
  sourceDetail     String?      @map("source_detail")
  lostReason       String?      @map("lost_reason")
  nextFollowUpDate DateTime?    @map("next_follow_up_date") @db.Date
  siteInspectionNeeded Boolean  @default(false) @map("site_inspection_needed")

  // ── Conversion ────────────────────────────────────
  convertedAt    DateTime?     @map("converted_at")
  convertedById  String?       @map("converted_by")

  // ── Relations ─────────────────────────────────────
  assignedToId   String?       @map("assigned_to")
  createdById    String        @map("created_by")

  assignedTo     User?         @relation("TicketAssignedTo", fields: [assignedToId], references: [id])
  convertedBy    User?         @relation("TicketConvertedBy", fields: [convertedById], references: [id])
  createdBy      User          @relation("TicketCreatedBy", fields: [createdById], references: [id])
  customer       Customer?

  notes          TicketNote[]
  followUps      TicketFollowUp[]
  statusHistory  TicketStatusHistory[]
  quotations     Quotation[]
  orders         Order[]
  designSpecs    DesignSpecification[]
  proposals      Proposal[]

  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@index([status])
  @@index([assignedToId])
  @@index([priority])
  @@index([phone])
  @@index([createdAt])
  @@map("tickets")
}

model TicketNote {
  id          String   @id @default(uuid())
  ticketId    String   @map("ticket_id")
  content     String   @db.Text
  type        NoteType @default(general)
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdBy User   @relation(fields: [createdById], references: [id])

  @@index([ticketId])
  @@map("ticket_notes")
}

model TicketFollowUp {
  id          String         @id @default(uuid())
  ticketId    String         @map("ticket_id")
  scheduledAt DateTime       @map("scheduled_at")
  status      FollowUpStatus @default(pending)
  outcome     String?        @db.Text
  createdById String         @map("created_by")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdBy User   @relation("TicketFollowUpCreatedBy", fields: [createdById], references: [id])

  @@index([ticketId])
  @@index([scheduledAt])
  @@index([status])
  @@map("ticket_follow_ups")
}

model DesignSpecification {
  id                  String           @id @default(uuid())
  ticketId            String           @map("ticket_id")
  customerId          String?          @map("customer_id")
  status              DesignSpecStatus @default(requested)

  // Requirement Input
  productType         ProductType      @map("product_type")
  requirementSummary  String?          @map("requirement_summary") @db.Text
  siteAreaSqft        Decimal?         @map("site_area_sqft") @db.Decimal(10, 2)
  siteType            String?          @map("site_type")
  siteEnvironment     String?          @map("site_environment") @db.Text
  powerAvailability   String?          @map("power_availability")
  specialRequirements String?          @map("special_requirements") @db.Text

  // Site Inspection
  siteInspectionDone  Boolean          @default(false) @map("site_inspection_done")
  siteInspectionDate  DateTime?        @map("site_inspection_date") @db.Date
  siteInspectionById  String?          @map("site_inspection_by")
  siteInspectionNotes String?          @map("site_inspection_notes") @db.Text
  sitePhotosUrl       String?          @map("site_photos_url")

  // Design Output
  recommendedProducts Json?            @map("recommended_products")
  configurationNotes  String?          @map("configuration_notes") @db.Text
  technicalSpecs      String?          @map("technical_specs") @db.Text
  bomItems            Json?            @map("bom_items")
  estimatedCost       Decimal?         @map("estimated_cost") @db.Decimal(12, 2)

  // Approval
  designedById        String?          @map("designed_by")
  reviewedById        String?          @map("reviewed_by")
  approvedAt          DateTime?        @map("approved_at")
  revisionNotes       String?          @map("revision_notes") @db.Text
  quotationId         String?          @map("quotation_id")

  createdById         String           @map("created_by")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  // Relations
  ticket           Ticket     @relation(fields: [ticketId], references: [id])
  customer         Customer?  @relation(fields: [customerId], references: [id])
  designedBy       User?      @relation("DesignedSpecs", fields: [designedById], references: [id])
  reviewedBy       User?      @relation("ReviewedSpecs", fields: [reviewedById], references: [id])
  siteInspectionBy User?      @relation("SiteInspections", fields: [siteInspectionById], references: [id])
  createdBy        User       @relation("CreatedSpecs", fields: [createdById], references: [id])
  quotation        Quotation? @relation(fields: [quotationId], references: [id])

  @@index([ticketId])
  @@index([status])
  @@map("design_specifications")
}

model Quotation {
  id                 String          @id @default(uuid())
  ticketId           String?         @map("ticket_id")
  customerId         String          @map("customer_id")
  validUntil         DateTime?       @map("valid_until") @db.Date
  subtotal           Decimal         @default(0) @db.Decimal(12, 2)
  taxAmount          Decimal         @default(0) @map("tax_amount") @db.Decimal(12, 2)
  discountAmount     Decimal         @default(0) @map("discount_amount") @db.Decimal(12, 2)
  totalAmount        Decimal         @default(0) @map("total_amount") @db.Decimal(12, 2)
  status             QuotationStatus @default(draft)
  termsAndConditions String?         @map("terms_and_conditions") @db.Text
  notes              String?         @db.Text
  createdById        String          @map("created_by")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  // Relations
  ticket       Ticket?               @relation(fields: [ticketId], references: [id])
  customer     Customer              @relation(fields: [customerId], references: [id])
  createdBy    User                  @relation(fields: [createdById], references: [id])
  items        QuotationItem[]
  orders       Order[]
  designSpecs  DesignSpecification[]

  @@index([customerId])
  @@index([status])
  @@map("quotations")
}

model Proposal {
  id                 String         @id @default(uuid())
  ticketId           String         @map("ticket_id")
  status             ProposalStatus @default(draft)
  validUntil         DateTime?      @map("valid_until") @db.Date
  subtotal           Decimal        @default(0) @db.Decimal(12, 2)
  taxAmount          Decimal        @default(0) @map("tax_amount") @db.Decimal(12, 2)
  discountAmount     Decimal        @default(0) @map("discount_amount") @db.Decimal(12, 2)
  totalAmount        Decimal        @default(0) @map("total_amount") @db.Decimal(12, 2)
  documentUrl          String?        @map("document_url") @db.Text
  documentOriginalName String?        @map("document_original_name")
  termsAndConditions   String?        @map("terms_and_conditions") @db.Text
  nextFollowUpDate     DateTime?      @map("next_follow_up_date") @db.Date
  createdById          String         @map("created_by")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  ticket    Ticket               @relation(fields: [ticketId], references: [id])
  createdBy User                 @relation("CreatedProposals", fields: [createdById], references: [id])
  items     ProposalItem[]
  notes     ProposalNote[]
  followUps ProposalFollowUp[]

  @@index([ticketId])
  @@index([status])
  @@map("proposals")
}

model ProposalNote {
  id          String   @id @default(uuid())
  proposalId  String   @map("proposal_id")
  content     String   @db.Text
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  proposal  Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdBy User     @relation(fields: [createdById], references: [id])

  @@index([proposalId])
  @@map("proposal_notes")
}

model ProposalFollowUp {
  id          String         @id @default(uuid())
  proposalId  String         @map("proposal_id")
  scheduledAt DateTime       @map("scheduled_at")
  status      FollowUpStatus @default(pending)
  outcome     String?        @db.Text
  createdById String         @map("created_by")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  proposal  Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  createdBy User     @relation("ProposalFollowUpCreatedBy", fields: [createdById], references: [id])

  @@index([proposalId])
  @@index([scheduledAt])
  @@index([status])
  @@map("proposal_follow_ups")
}

model ProposalItem {
  id              String   @id @default(uuid())
  proposalId      String   @map("proposal_id")
  productName     String   @map("product_name")
  description     String?  @db.Text
  quantity        Int      @default(1)
  unitPrice       Decimal  @map("unit_price") @db.Decimal(12, 2)
  discountPercent Decimal  @default(0) @map("discount_percent") @db.Decimal(5, 2)
  taxPercent      Decimal  @default(18) @map("tax_percent") @db.Decimal(5, 2)
  totalPrice      Decimal  @map("total_price") @db.Decimal(12, 2)
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@map("proposal_items")
}

model QuotationItem {
  id              String    @id @default(uuid())
  quotationId     String    @map("quotation_id")
  productName     String    @map("product_name")
  description     String?   @db.Text
  quantity        Int       @default(1)
  unitPrice       Decimal   @map("unit_price") @db.Decimal(12, 2)
  discountPercent Decimal   @default(0) @map("discount_percent") @db.Decimal(5, 2)
  taxPercent      Decimal   @default(18) @map("tax_percent") @db.Decimal(5, 2)
  totalPrice      Decimal   @map("total_price") @db.Decimal(12, 2)
  sortOrder       Int       @default(0) @map("sort_order")
  createdAt       DateTime  @default(now()) @map("created_at")

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@map("quotation_items")
}

model Order {
  id                   String      @id @default(uuid())
  customerId           String      @map("customer_id")
  ticketId             String?     @map("ticket_id")
  quotationId          String?     @map("quotation_id")
  status               OrderStatus @default(created)
  totalAmount          Decimal     @map("total_amount") @db.Decimal(12, 2)
  notes                String?     @db.Text
  expectedDeliveryDate DateTime?   @map("expected_delivery_date") @db.Date
  createdById          String      @map("created_by")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  // Relations
  customer    Customer     @relation(fields: [customerId], references: [id])
  ticket      Ticket?      @relation(fields: [ticketId], references: [id])
  quotation   Quotation?   @relation(fields: [quotationId], references: [id])
  createdBy   User         @relation(fields: [createdById], references: [id])
  items       OrderItem[]

  @@index([customerId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String   @map("order_id")
  productName String   @map("product_name")
  description String?  @db.Text
  quantity    Int      @default(1)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal  @map("total_price") @db.Decimal(12, 2)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}

model TicketStatusHistory {
  id          String       @id @default(uuid())
  ticketId    String       @map("ticket_id")
  status      TicketStatus
  enteredAt   DateTime     @map("entered_at")
  exitedAt    DateTime?    @map("exited_at")
  durationMs  BigInt?      @map("duration_ms")
  changedById String       @map("changed_by")

  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  changedBy User   @relation("StatusHistoryChangedBy", fields: [changedById], references: [id])

  @@index([ticketId])
  @@map("ticket_status_history")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String   // CREATE, UPDATE, DELETE, STATUS_CHANGE, LOGIN, LOGOUT, etc.
  entityType String   @map("entity_type") // leads, orders, users, etc.
  entityId   String   @map("entity_id")
  changes    Json?    // { before: {...}, after: {...} }
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
